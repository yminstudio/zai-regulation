#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

HOST="${API_HOST:-0.0.0.0}"
PORT="${API_PORT:-8000}"
RELOAD="${API_RELOAD:-0}"

cmd=(python -m uvicorn src.server:app --host "$HOST" --port "$PORT")
if [[ "$RELOAD" == "1" ]]; then
  cmd+=(--reload)
fi

exec "${cmd[@]}"
