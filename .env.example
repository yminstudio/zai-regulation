# Secrets only. Do NOT commit real values.
# Ollama API endpoint
# - 로컬 직결 예시: http://localhost:11434
# - 사내 프록시 예시: https://ai.zeroin.co.kr/dev
OLLAMA_BASE_URL=http://localhost:11434

# 사내 API Gateway에서 인증이 필요할 때만 사용
OLLAMA_API_KEY=

# 모델은 환경변수로만 교체 (코드 수정 금지)
ANSWER_MODEL=gpt-oss-20b-128k:latest
SUMMARIZE_MODEL=gpt-oss-20b-128k:latest

# 임베딩 백엔드 선택: openai | local_sentence_transformers
EMBEDDING_BACKEND=local_sentence_transformers

# OpenAI 임베딩 (EMBEDDING_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 로컬 임베딩 (EMBEDDING_BACKEND=local_sentence_transformers)
# 후보 예시:
# - BAAI/bge-m3
# - intfloat/multilingual-e5-large-instruct
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_EMBEDDING_DEVICE=
LOCAL_EMBEDDING_NORMALIZE=true

# 앱 실행 포트 (master 개발 기본 8012)
API_PORT=8012

GW_USER_ID=
GW_PASSWORD=

# Optional overrides
APP_ENV=dev
# CONFIG_FILE=config/dev.yaml
# WEAVIATE_URL=http://localhost:8080
# PROJECT_WEAVIATE_DB_CLASS=ZaiRegulation_db
